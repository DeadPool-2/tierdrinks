[Unit]
Description=TierDrinks — energy drink tier list (zero-deps node:http)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/tierdrinks
Environment=PORT=3000
# /usr/bin/env resolves node from PATH (works with apt-node or nvm shims)
ExecStart=/usr/bin/env node server.js
Restart=on-failure
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
